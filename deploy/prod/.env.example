# ===============================================================
# Zen-Codes / API-Station production .env
# Generated from deploy/.env.example, do NOT commit actual .env
# ===============================================================

# Host binding
BIND_HOST=127.0.0.1             # Bind only to loopback; Caddy fronts on :443
SERVER_PORT=18080                # Port Caddy reverse_proxy'd to

# PostgreSQL (random hex 16)
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=__RANDOM_HEX_16__
POSTGRES_DB=sub2api

# Redis (empty = no auth; VPS-only)
REDIS_PASSWORD=

# JWT / TOTP secrets (random hex 32)
JWT_SECRET=__RANDOM_HEX_32__
TOTP_ENCRYPTION_KEY=__RANDOM_HEX_32__

# Admin bootstrap (only used on first launch)
ADMIN_EMAIL=admin@zen-codes.com
ADMIN_PASSWORD=__RANDOM_BASE64_16_URLSAFE__

# Timezone
TZ=Asia/Shanghai

# Feishu webhook is configured via Admin UI / Settings API
# (DB-backed: apistation_feishu_webhook_url in settings table)
